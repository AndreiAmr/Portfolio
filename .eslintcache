            <input type=\"email\" name=\"email\" id=\"email\" required />\r\n            <label htmlFor=\"email\"> Email </label>\r\n          </InputArea>\r\n          <InputArea>\r\n            <input type=\"text\" name=\"title\" id=\"title\" required />\r\n            <label htmlFor=\"title\"> Assunto </label>\r\n          </InputArea>\r\n          <InputArea>\r\n            <input type=\"text\" name=\"body\" id=\"body\" required />\r\n            <label htmlFor=\"body\"> Mensagem </label>\r\n          </InputArea>\r\n\r\n          <small> {dataContent.pages[2].formTip} </small>\r\n\r\n          <button type='submit'> Enviar </button>\r\n        </FormArea>\r\n        \r\n      </div>\r\n\r\n      <SocialsNetworks>\r\n        <h2> { dataContent.pages[2].socialNetworksText} </h2>\r\n        <div>\r\n          <a className='whatsapp-button' target=\"_blank\" href='https://api.whatsapp.com/send?phone=5511992405312&text=Ol%C3%A1,%20Andrei.%20Vi%20seu%20site%20e%20gostaria%20de%20bater%20um%20papo%20contigo!'> <FaWhatsapp /> </a>\r\n          <a className='linkedin-button' target=\"_blank\" href='https://www.linkedin.com/in/andrei-amaral-327493191/'> <FaLinkedin /> </a>\r\n        </div>\r\n\r\n\r\n        <h1> {dataContent.pages[2].thanks}</h1>\r\n      </SocialsNetworks>\r\n\r\n    </Container>\r\n  );\r\n}\r\n\r\nexport default Contact;",["59","60"],"H:\\projetos\\portfolio\\src\\App.tsx",[],"H:\\projetos\\portfolio\\src\\pages\\ProjectDetail.tsx",[],"H:\\projetos\\portfolio\\src\\components\\Tech.tsx",[],"H:\\projetos\\portfolio\\src\\pages\\Home.tsx",[],"H:\\projetos\\portfolio\\src\\data\\pages.ts",["61"],"H:\\projetos\\portfolio\\src\\appStyle.ts",[],"H:\\projetos\\portfolio\\src\\styles\\components\\asidebar.ts",[],"H:\\projetos\\portfolio\\src\\pages\\Portifolio.tsx",[],"H:\\projetos\\portfolio\\src\\styles\\pages\\projects.ts",[],"H:\\projetos\\portfolio\\src\\index.tsx",[],"H:\\projetos\\portfolio\\src\\styles\\pages\\home.ts",[],{"ruleId":"62","severity":1