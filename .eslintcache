mport { Container, Form, FormContainer, SocialNetworks } from '../styles/pages/contact';\r\nimport dataContent from \"../data/pages\";\r\nimport EmailIcon from \"../images/emailIcon.svg\";\r\n\r\nconst Contact: React.FC = () => {\r\n  const [name, setName] = useState<string>();\r\n  const [email, setEmail] = useState<string>();\r\n  const [title, setTitle] = useState<string>();\r\n  const [message, setMessage] = useState<string>();\r\n\r\n  init(\"user_pBCnrjW9bWoLlE0iqAoup\");\r\n\r\n  async function handleSendEmail(e: FormEvent) {\r\n    // e.preventDefault();\r\n    emailjs.send(\"portifolio_email_id\", \"template_4s219vx\", {\r\n      from_name: name,\r\n      message: message,\r\n      from_email: email,\r\n    }).then(e => {\r\n\r\n    }); \r\n  }\r\n\r\n\r\n  return (\r\n    <Container>\r\n      <h1>Formulário para email</h1>\r\n\r\n      <FormContainer>\r\n        <img src={EmailIcon} alt=\"Email Icone\" className=\"email-icon\" />\r\n\r\n        <Form>\r\n          <input type=\"text\" placeholder='Nome' required minLength={3} onChange={e => setName(e.target.value)} />\r\n          <input type=\"email\" placeholder='Email' required onChange={e => setEmail(e.target.value)} />\r\n          <input type=\"text\" placeholder=\"Assunto\" required onChange={e => setTitle(e.target.value)} />\r\n          <textarea id=\"\" cols={20} rows={10} placeholder=\"Mensagem\" required minLength={20} onChange={e => setMessage(e.target.value)} ></textarea>\r\n\r\n          <button type='submit' onClick={handleSendEmail}> Enviar</button>\r\n        </Form>\r\n\r\n      </FormContainer>\r\n      <h1> Redes Sociais </h1>\r\n      <SocialNetworks>\r\n\r\n        <a className='linkedin-button' href=\"https://www.linkedin.com/in/andrei-amaral-327493191/\" >\r\n          <FaLinkedin />\r\n          Linkedin\r\n        </a>\r\n        <a className='whatsapp-button' target=\"_blank\" href='https://api.whatsapp.com/send?phone=5511992405312&text=Ol%C3%A1,%20Andrei.%20Vi%20seu%20site%20e%20gostaria%20de%20bater%20um%20papo%20contigo!'> <FaWhatsapp /> WhatsApp </a>\r\n      </SocialNetworks>\r\n\r\n    </Container>\r\n  );\r\n}\r\n\r\nexport default Contact;","H:\\projetos\\portfolio\\src\\App.tsx",[],"H:\\projetos\\portfolio\\src\\pages\\ProjectDetail.tsx",[],["68","69"],"H:\\projetos\\portfolio\\src\\components\\Tech.tsx",[],"H:\\projetos\\portfolio\\src\\pages\\Home.tsx",[],"H:\\projetos\\portfolio\\src\\data\\pages.ts",["70"],"H:\\projetos\\portfolio\\src\\appStyle.ts",[],"H:\\projetos\\portfolio\\src\\styles\\components\\asidebar.ts",[],"H:\\projetos\\portfolio\\src\\pages\\Portifolio.tsx",[],["71","72"],"H:\\projetos\\portfolio\\src\\styles\\pages\\projects.ts",[],"H:\\projetos\\portfolio\\src\\index.tsx",[],"H:\\projetos\\portfolio\\src\\styles\\pages\\home.ts",[],"H:\\projetos\\portfolio\\src\\styles\\components\\tech.ts",[],"H:\\projetos\\portfolio\\src\\components\\Asidebar.tsx",[],{"ruleId":"73","severity":1,"message":"74","line":8,"column":8,"nodeType":"75","messageId":"76","endLine":8,"endColumn":19},{"ruleId":"73","severity":1,"message":"77","line":14,"column":10,"nodeType":"75","messageId":"76","endLine":14,"endColumn":15},{"ruleId":"78","severity":1,"message":"79","line":55,"column":40,"nodeType":"80","endLine":55,"endColumn":55},{"ruleId":"81","replacedBy":"82"},{"ruleId":"83","replacedBy":"84"},{"ruleId":"85","severity":1,"message":"86","line":1,"column":1,"nodeType":"87","endLine":79,"endColumn":2},{"ruleId":"81","replacedBy":"88"},{"ruleId":"83","replacedBy":"89"},"@typescript-eslint/no-unused-vars","'dataContent' is defined but never used.","Identifier","unusedVar","'title' is assigned a value but never used.","react/jsx-no-target-blank","Using target=\"_blank\" without rel=\"noreferrer\" is a security risk: see https://html.spec.whatwg.org/multipage/links.html#link-type-noopener","JSXAttribute","no-native-reassign",["90"],"no-negated-in-lhs",["91"],"import/no-anonymous-default-export","Assign object to a variable before exportin