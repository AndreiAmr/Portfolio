>\r\n          <InputArea>\r\n            <input type=\"name\" name=\"name\" id=\"name\" required />\r\n            <label htmlFor=\"name\"> Nome </label>\r\n          </InputArea>\r\n          <InputArea>\r\n            <input type=\"email\" name=\"email\" id=\"email\" required />\r\n            <label htmlFor=\"email\"> Email </label>\r\n          </InputArea>\r\n          <InputArea>\r\n            <input type=\"text\" name=\"title\" id=\"title\" required />\r\n            <label htmlFor=\"title\"> Assunto </label>\r\n          </InputArea>\r\n          <InputArea>\r\n            <input type=\"text\" name=\"body\" id=\"body\" required />\r\n            <label htmlFor=\"body\"> Mensagem </label>\r\n          </InputArea>\r\n\r\n          <small> * Todos os campos são obrigatórios. </small>\r\n\r\n          <button type='submit'> Enviar </button>\r\n        </FormArea>\r\n        \r\n      </div>\r\n\r\n      <SocialsNetworks>\r\n        <h2> Ou envie-me uma mensagem em minhas redes sociais =)</h2>\r\n        <div>\r\n          <a className='whatsapp-button' target=\"_blank\" href='https://api.whatsapp.com/send?phone=5511992405312&text=Ol%C3%A1,%20Andrei.%20Vi%20seu%20site%20e%20gostaria%20de%20bater%20um%20papo%20contigo!'> <FaWhatsapp /> </a>\r\n          <a className='linkedin-button' target=\"_blank\" href='https://www.linkedin.com/in/andrei-amaral-327493191/'> <FaLinkedin /> </a>\r\n        </div>\r\n\r\n\r\n        <h1> Obrigado por ter chegado até aqui!!</h1>\r\n      </SocialsNetworks>\r\n\r\n    </Container>\r\n  );\r\n}\r\n\r\nexport default Contact;","H:\\projetos\\portfolio\\src\\App.tsx",[],"H:\\projetos\\portfolio\\src\\pages\\ProjectDetail.tsx",[],"H:\\projetos\\portfolio\\src\\components\\Tech.tsx",[],"H:\\projetos\\portfolio\\src\\pages\\Home.tsx",["30"],{"ruleId":"31","severity":1,"message":"32","line":2,"column":8,"nodeType":"33","messageId":"34","endLine":2,"endColumn":9},{"ruleId":"35","severity":1,"message":"36","line":42,"column":42,"nodeType